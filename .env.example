# FLEXT Plugin System Configuration
# Copy this to .env and customize for your environment

DEBUG=true
# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

AUTO_DISCOVERY=true
# Plugin Discovery
PLUGIN_DIRECTORIES=/opt/flext/plugins,~/.flext/plugins
PLUGIN_REGISTRY_URL=https://hub.meltano.com
SCAN_INTERVAL=300

AUTO_INSTALL=false
CACHE_DIR=/opt/flext/cache
# Plugin Installation
INSTALL_DIR=/opt/flext/plugins
TEMP_DIR=/tmp/flext-plugins

# Plugin Management
HOT_RELOAD=true
MAX_PLUGINS=100
PLUGIN_TIMEOUT=60
RELOAD_INTERVAL=5

ISOLATED_ENVIRONMENTS=true
PYTHON_VERSION=3.13
SHARED_DEPENDENCIES=false
# Virtual Environment Management
VENV_BACKEND=virtualenv

# Plugin Registry
REGISTRY_BACKEND=filesystem
REGISTRY_PATH=/opt/flext/registry
REGISTRY_SYNC_INTERVAL=3600
REMOTE_REGISTRY=false

ALLOWED_IMPORTS=
RESOURCE_LIMITS=true
# Security & Sandboxing
SANDBOX_ENABLED=true
SECURITY_POLICY=strict

CODE_ANALYSIS=true
# Plugin Validation
SCHEMA_VALIDATION=true
SECURITY_SCAN=true
SIGNATURE_VERIFICATION=false

CONFLICT_RESOLUTION=auto
# Dependency Management
DEPENDENCY_RESOLUTION=strict
UPDATE_STRATEGY=conservative
VERSION_CONSTRAINTS=true

ERROR_TRACKING=true
PERFORMANCE_MONITORING=true
# Monitoring & Metrics
PLUGIN_METRICS=true
USAGE_ANALYTICS=false

AUTO_RELOAD_DEV=true
DEBUG_PLUGINS=false
# Development Tools
DEVELOPMENT_MODE=true
PROFILING_ENABLED=false

# Plugin Communication
IPC_METHOD=grpc
MAX_CONNECTIONS=10
PLUGIN_PORT_RANGE=50100-50200
TIMEOUT=30
