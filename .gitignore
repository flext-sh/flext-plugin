.internal.invalid
.env.production

# ============================================================================
# PROJECT SPECIFIC - FLEXT-PLUGIN
# ============================================================================

# Archive directory
archive/

# Reports directory
reports/

# Old requirements.txt (use pyproject.toml)
requirements.txt

# Dev backups
.dev_deps_backup_*
*_backup_*

# AI-generated reports and migration files
*_REPORT.md
*_REPORT_*.md
CONFIG_MIGRATION*.md
FLEXT_*_MIGRATION*.md
DEVELOPMENT_STANDARDS.md
DUPLICATION_REPORT.md

# Manual fix scripts
fix_*.py
*_fix.py
*_validation.py
validate_*.*

# Legacy artifacts
data/
output/
state/
pipeline_state/
execution_logs/

# Runtime data
runtime/
cache/
.cache/

# Temporary files
*.tmp
*.temp
*.bak

# ============================================================================
# ALWAYS INCLUDE EXCEPTIONS
