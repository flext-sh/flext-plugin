# ============================================================================
# FLEXT-PLUGIN - Plugin System Framework .gitignore
# Python 3.13 | Poetry | Plugin Architecture | Dynamic Loading
# ============================================================================

# ============================================================================
# JUNK FILES - NEVER COMMIT THESE
# ============================================================================

# Archive and backup directories  
archive/
archives/
backup/
backups/
.backup/
*_backup/
*_backup_*/
.plugin_backups
# AI-generated files and reports
*_REPORT*.md
*_ANALYSIS*.md
*_SUMMARY*.md  
*_FINDINGS*.md
CLAUDE*.md
CONFIG_MIGRATION*.md
DEVELOPMENT_STANDARDS*.md
DUPLICATION_REPORT*.md
LINT_CORRECTIONS*.md
*.ai.md
*.ai.txt

# Backup files with timestamps
*_20250*.bak
*_202507*.bak
*_202506*.bak
*.md_20250*
README_20250*.bak

# Generic backup patterns
*.bak
*.backup
*.orig
*.syntax_backup  
*.broken
*.tmp.bak
*_temp.py
*_temp.md

# Fix scripts and validation files
fix_*.py
*_fix.py
*_validation.py
validate_*.py
investigate_*.py
temp_*.py
debug_*.py

# Tool reports and analysis
*_analysis.txt
*_report.txt
*_output.txt
analysis_temp/
report_*/
reports/
reports_*/
temp_test_*/

# ============================================================================
# PYTHON ARTIFACTS
# ============================================================================

# Python artifacts
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd

# Distribution / packaging
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Testing and coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Development tools
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Virtual environments
.env
.venv/
env/
venv/
ENV/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# System files
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================================
# PLUGIN SYSTEM ARTIFACTS
# ============================================================================

# Plugin cache and runtime
plugin_cache/
.plugin_cache/
plugins_loaded/
plugin_registry/

# Dynamic plugin loading
*.plugin.cache
plugin_metadata/
plugin_configs/
plugin_state/

# Plugin packages (compiled)
*.pyz
*.pex
plugins_compiled/

# Plugin discovery
discovered_plugins/
plugin_scan_cache/
plugin_index.json

# Plugin installation
plugin_install_temp/
plugin_downloads/
plugin_packages/

# ============================================================================
# PLUGIN DEVELOPMENT
# ============================================================================

# Plugin templates
plugin_templates/
template_cache/

# Plugin testing
plugin_test_data/
test_plugins/
mock_plugins/

# Plugin documentation
plugin_docs/
api_docs/
plugin_help/

# Plugin examples
example_plugins/
sample_plugins/
demo_plugins/

# ============================================================================
# PLUGIN CONFIGURATION
# ============================================================================

# Plugin configurations (sensitive)
plugin_secrets/
plugin_credentials/
*.plugin.key
*.plugin.token

# Plugin settings
plugin_settings/
user_plugins/
custom_plugins/

# Plugin logs
plugin.log
plugin_loader.log
plugin_manager.log
*.plugin.log

# Plugin errors
plugin_errors/
failed_plugins/
plugin_exceptions/

# ============================================================================
# DYNAMIC LOADING ARTIFACTS
# ============================================================================

# Bytecode cache
*.pyc.cache
bytecode_cache/

# Import cache
import_cache/
module_cache/

# Dynamic imports
dynamic_modules/
loaded_modules/

# Entry points
entry_points_cache/
setup_cache/

# ============================================================================
# EXTENSION SYSTEM
# ============================================================================

# Extensions
extensions/
ext_cache/
extension_data/

# Hooks and callbacks
hooks_cache/
callback_registry/

# Event system
events_cache/
event_handlers/

# Middleware
middleware_cache/
middleware_stack/

# ============================================================================
# LOGS AND TEMPORARY FILES
# ============================================================================

# Logs
*.log
logs/
plugin_logs/

# Temporary files
*.tmp
temp/
tmp/
plugin_temp/

# Data files
data/
plugin_data/

# Force include critical files
!pyproject.toml
!Makefile
!README.md
!plugin_interface.py
!example_plugin.py
!docker-compose.yml
